# ── LLM provider ────────────────────────────────────────────────────────
# One of:
#   gemma  — live API calls to Google AI Studio (needs GOOGLE_API_KEY)
#   file   — write each request to data/llm_request_<id>.json and poll for
#            data/llm_response_<id>.json. Lets a human or external agent
#            hand-craft every turn. No API key needed.
#   mock   — deterministic canned responses (used by the test suite).
# The provider abstraction is in src/oyez/ai/base.py — new providers slot
# in there. See backend/README.md "Provider modes" for the full file
# protocol.
LLM_PROVIDER=gemma

# ── Gemma (Google AI Studio) ────────────────────────────────────────────
# Either GOOGLE_API_KEY or GEMINI_API_KEY works (the SDK picks up either).
GOOGLE_API_KEY=your_google_ai_studio_key_here
# GEMINI_API_KEY=your_google_ai_studio_key_here

# Model id. Defaults to gemma-4-26b-a4b-it (MoE, 4B active, fast).
# Alternatives: gemma-4-31b-it (dense), gemma-4-e4b-it / gemma-4-e2b-it (small).
GEMMA_MODEL=gemma-4-26b-a4b-it

# ── Server ──────────────────────────────────────────────────────────────
PORT=8000

# Comma-separated origins are not supported by pydantic-settings out of the
# box; if you need to override, set CORS_ORIGINS='["http://localhost:5173"]'
# as a JSON array. Defaults already include the Vite dev server.

# ── Storage ─────────────────────────────────────────────────────────────
# Sessions and temp uploads live under this directory. Created on startup.
DATA_DIR=./data
