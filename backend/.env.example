# Which LLM backend to use: "claude" or "gemini"
# Default is gemini + Gemma (free open-weights model via Google AI Studio).
LLM_PROVIDER=gemini

# --- Claude (Anthropic) ---
# Required when LLM_PROVIDER=claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional model override
CLAUDE_MODEL=claude-haiku-4-5

# --- Gemini (Google) ---
# Required when LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
# Optional model override (e.g. gemini-2.5-flash for faster paid model)
GEMINI_MODEL=gemma-4-26b-a4b-it

PORT=3001
